# Copy this file to .env.local and fill in real values.
# In production (Vercel), set these in Project Settings → Environment Variables.

# Vercel Blob storage — get this from: Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=

# Resend API key — get this from: https://resend.com/api-keys
RESEND_API_KEY=

# The email address that receives each new submission
ADMIN_EMAIL=ben@alfredapp.com.au

# "From" address on submission emails. Must be a domain you've verified in Resend.
# For initial testing you can use Resend's sandbox: onboarding@resend.dev
FROM_EMAIL=onboarding@resend.dev

# Public site metadata (shown on page, doesn't affect functionality)
NEXT_PUBLIC_SITE_NAME=The Read
NEXT_PUBLIC_CONTACT_EMAIL=ben@alfredapp.com.au

# Founder name shown in the hero credibility block. First name is fine.
NEXT_PUBLIC_FOUNDER_NAME=Ben
# Optional URL for a founder photo. A square crop (500x500+) works best.
# If blank, the hero renders an initial-in-a-circle placeholder instead.
NEXT_PUBLIC_FOUNDER_PHOTO_URL=

# WhatsApp group invite link — shown as a "Join the chat" CTA on the success page.
# Leave blank to hide the block. Get the link from WhatsApp → Group Info → Invite via link.
NEXT_PUBLIC_WHATSAPP_INVITE_URL=

# PostHog — event tracking + session replay.
# Get the project key from: PostHog → Project Settings → Project API Key.
# Leave blank to disable analytics entirely (no-ops in the browser).
NEXT_PUBLIC_POSTHOG_KEY=
# Regional host — "https://us.i.posthog.com" for US Cloud, "https://eu.i.posthog.com" for EU.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
